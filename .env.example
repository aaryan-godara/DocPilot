# ==================================================
# DocPilot — Environment Variables
# ==================================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# ==================================================

# Application
APP_NAME=DocPilot
APP_VERSION=0.1.0
DEBUG=true

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Paths
UPLOAD_DIR=data/raw

# Logging
LOG_LEVEL=INFO

# Groq (required for Q&A) — Get free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# LLM Settings
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1000

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval
TOP_K=5

# ChromaDB
CHROMA_PERSIST_DIR=data/processed/chroma
