# ==================================================
# DocPilot — Environment Variables
# ==================================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# ==================================================

# Application
APP_NAME=DocPilot
APP_VERSION=0.1.0
DEBUG=true

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Paths
UPLOAD_DIR=data/raw

# Logging
LOG_LEVEL=INFO

# xAI / Grok (required for Q&A)
XAI_API_KEY=xai-your-key-here
XAI_BASE_URL=https://api.x.ai/v1

# LLM Settings
LLM_MODEL=grok-3-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1000

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval
TOP_K=5

# ChromaDB
CHROMA_PERSIST_DIR=data/processed/chroma
