# ==================================================
# AskMyBook — Environment Variables
# ==================================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# ==================================================

# Application
APP_NAME=AskMyBook
APP_VERSION=0.1.0
DEBUG=true

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Paths
UPLOAD_DIR=data/raw

# Logging
LOG_LEVEL=INFO

# OpenAI (required in Week 2+)
OPENAI_API_KEY=sk-your-key-here

# ChromaDB (required in Week 2+)
CHROMA_PERSIST_DIR=data/processed/chroma
